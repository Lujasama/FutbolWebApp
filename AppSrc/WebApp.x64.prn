37750>>>                // If from main, this is a propbably a main file Select to Zoom.
37750>>>                Case Break
37751>>>
37751>>>            Case (NavigateData.eNavigateType = nfFromParent)
37754>>>                // If from parent, this is a constrained drill down.
37754>>>                Case Break
37755>>>
37755>>>            Case (NavigateData.eNavigateType = nfFromChild)
37758>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37758>>>                Case Break
37759>>>
37759>>>            Case Else // must be nfUndefined
37759>>>
37759>>>        Case End
37759>>>
37759>>>        Send SetActionButtons
37760>>>
37760>>>    End_Procedure
37761>>>
37761>>>End_Object 
