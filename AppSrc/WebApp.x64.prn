39054>>>        WebSet pbRender of oEditBtn to False
39055>>>        WebSet pbRender of oSaveBtn to False
39056>>>        WebSet pbRender of oCancelChangesBtn to False
39057>>>        WebSet pbRender of oDeleteBtn to False
39058>>>
39058>>>        If (NavigateData.bReadOnly) Begin
39060>>>            WebSet pbRender of oEditBtn to True
39061>>>        End
39061>>>>
39061>>>        Else Begin
39062>>>            WebSet pbRender of oSaveBtn to True
39063>>>            WebSet pbRender of oCancelChangesBtn to True
39064>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39065>>>        End
39065>>>>
