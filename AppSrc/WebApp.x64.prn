37723>>>
37723>>>        // let's hide all buttons and then Show the ones we want
37723>>>        WebSet pbRender of oEditBtn to False
37724>>>        WebSet pbRender of oSaveBtn to False
37725>>>        WebSet pbRender of oCancelChangesBtn to False
37726>>>        WebSet pbRender of oDeleteBtn to False
37727>>>
37727>>>        If (NavigateData.bReadOnly) Begin
37729>>>            WebSet pbRender of oEditBtn to True
37730>>>        End
37730>>>>
37730>>>        Else Begin
37731>>>            WebSet pbRender of oSaveBtn to True
37732>>>            WebSet pbRender of oCancelChangesBtn to True
37733>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37734>>>        End
37734>>>>
37734>>>    End_Procedure
