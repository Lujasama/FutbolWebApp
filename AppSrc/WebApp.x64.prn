36684>>>>>>>        If (bRequireTimeCost) Begin
36686>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36687>>>>>>>        End
36687>>>>>>>>
36687>>>>>>>        Else Begin
36688>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36689>>>>>>>        End
36689>>>>>>>>
36689>>>>>>>        
36689>>>>>>>        Function_Return bOk
36690>>>>>>>    End_Function
36691>>>>>>>    
36691>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36693>>>>>>>        UChar[] ucaSalt
36694>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36695>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36698>>>>>>>        
36698>>>>>>>        If (num_arguments > 4) Begin
36700>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36701>>>>>>>        End
36701>>>>>>>>
36701>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36702>>>>>>>    End_Function
36703>>>>>>>    
36703>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36705>>>>>>>        Boolean bRequiresTimeCost
36705>>>>>>>        UInteger uiAlgo uiTimeCost
36705>>>>>>>        Integer iBegin iEnd
36705>>>>>>>        String sSalt
36705>>>>>>>        
36705>>>>>>>        Move 1 to iBegin
36706>>>>>>>        
36706>>>>>>>        // Parse Algo
36706>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36707>>>>>>>        If (not(iEnd)) Function_Return False
36710>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36711>>>>>>>        
36711>>>>>>>        // Parse Salt
36711>>>>>>>        Move (iEnd + 1) to iBegin
36712>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36713>>>>>>>        If (not(iEnd)) Function_Return False
36716>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36717>>>>>>>        
36717>>>>>>>        Case Begin
36717>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36719>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36722>>>>>>>                Move True to bRequiresTimeCost
36723>>>>>>>                Case Break
36724>>>>>>>            Case Else
36724>>>>>>>                Error 8710 "Invalid algorithm selected."
36725>>>>>>>>
36725>>>>>>>                Function_Return False
36726>>>>>>>        Case End
36726>>>>>>>        
36726>>>>>>>        // Parse optional timecost
36726>>>>>>>        If (bRequiresTimeCost) Begin
36728>>>>>>>            Move (iEnd + 1) to iBegin
36729>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36730>>>>>>>            If (not(iEnd)) Function_Return False
36733>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36734>>>>>>>        End
36734>>>>>>>>
36734>>>>>>>        
36734>>>>>>>        // Parse rest hash
36734>>>>>>>        Move (iEnd + 1) to iBegin
36735>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36736>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36739>>>>>>>        
36739>>>>>>>        // Base64Decode
36739>>>>>>>        UChar[] ucaSalt
36740>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36741>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36744>>>>>>>        
36744>>>>>>>        // Create new hash
36744>>>>>>>        String sNewHash
36744>>>>>>>        If (bRequiresTimeCost) Begin
36746>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36748>>>>>>>                Function_Return False 
36749>>>>>>>            End
36749>>>>>>>>
36749>>>>>>>        End
36749>>>>>>>>
36749>>>>>>>        Else Begin
36750>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36752>>>>>>>                Function_Return False 
36753>>>>>>>            End
36753>>>>>>>>
36753>>>>>>>        End
36753>>>>>>>>
36753>>>>>>>        Function_Return (sNewHash = sHash)
36754>>>>>>>    End_Function
36755>>>>>>>    
36755>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36757>>>>>>>        Boolean bRequireTimeCost
36757>>>>>>>        UBigInt ullSize
36757>>>>>>>        UChar[] ucaSalt
36758>>>>>>>        String sSalt
36758>>>>>>>        
36758>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36759>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36760>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36763>>>>>>>        
36763>>>>>>>        Case Begin
36763>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36765>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36766>>>>>>>                Move True to bRequireTimeCost
36767>>>>>>>                Case Break
36768>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36771>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36772>>>>>>>                Move True to bRequireTimeCost
36773>>>>>>>                Case Break
36774>>>>>>>            Case Else
36774>>>>>>>                Error 8710 "Invalid algorithm selected."
36775>>>>>>>>
36775>>>>>>>                Function_Return 0
36776>>>>>>>        Case End
36776>>>>>>>        
36776>>>>>>>        // calculate base64 in a non-floating-manner
36776>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36777>>>>>>>        
36777>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36778>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36779>>>>>>>        If (bRequireTimeCost) Begin
36781>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36782>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36783>>>>>>>        End
36783>>>>>>>>
36783>>>>>>>        Else Begin
36784>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36785>>>>>>>        End
36785>>>>>>>>
36785>>>>>>>        
36785>>>>>>>        Function_Return ullSize
36786>>>>>>>    End_Function
36787>>>>>>>End_Class
36788>>>>>>>
36788>>>>>>>Class cPasswordHasher is a cObject
36789>>>>>>>    
36789>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36790>>>>>>>    
36790>>>>>>>    Procedure Construct_Object
36792>>>>>>>        Forward Send Construct_Object
36794>>>>>>>        
36794>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36795>>>>>>>        Property UInteger   puiSaltSize         16
36796>>>>>>>        
36796>>>>>>>        Property UInteger   puiOptTimeCost      420000
36797>>>>>>>    End_Procedure
36798>>>>>>>    
36798>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36800>>>>>>>        Boolean bOk
36800>>>>>>>        UInteger uiAlgo
36800>>>>>>>        Get peAlgorithm to uiAlgo
36801>>>>>>>        
36801>>>>>>>        Case Begin
36801>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36803>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36806>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36807>>>>>>>                Case Break
36808>>>>>>>            Case Else
36808>>>>>>>                Error 8710 "Invalid algorithm selected."
36809>>>>>>>>
36809>>>>>>>                Function_Return False
36810>>>>>>>        Case End
36810>>>>>>>        
36810>>>>>>>        Function_Return bOk
36811>>>>>>>    End_Function
36812>>>>>>>    
36812>>>>>>>    Function RequiredBufferSize Returns UBigInt
36814>>>>>>>        UBigInt ullSize
36814>>>>>>>        UInteger uiAlgo
36814>>>>>>>        Get peAlgorithm to uiAlgo
36815>>>>>>>        
36815>>>>>>>        Case Begin
36815>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36817>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36820>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36821>>>>>>>                Case Break
36822>>>>>>>            Case Else
36822>>>>>>>                Error 8710 "Invalid algorithm selected."
36823>>>>>>>>
36823>>>>>>>                Function_Return 0
36824>>>>>>>        Case End
36824>>>>>>>        
36824>>>>>>>        Function_Return ullSize
36825>>>>>>>    End_Function
36826>>>>>>>
36826>>>>>>>End_Class
