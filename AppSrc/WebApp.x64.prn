37221>>>    Procedure DoLogin
37224>>>        String sLoginName sPassword sPrevStateHash
37224>>>        Boolean bResult
37224>>>        
37224>>>        WebGet psValue of oLoginName to sLoginName
37225>>>        WebGet psValue of oPassword to sPassword
37226>>>        
37226>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37227>>>        
37227>>>        If (bResult) Begin
37229>>>            Send Hide of oLogin
37230>>>            Send ShowHeader of ghoWebApp
37231>>>            WebSet psCSSClass of ghoWebApp to ""
37232>>>            
37232>>>            WebGet psPrevStateHash to sPrevStateHash
37233>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37234>>>            
37234>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37234>>>            WebSet psValue of oLoginName to ""
37235>>>            WebSet psValue of oPassword  to ""
37236>>>            WebSet pbVisible of oWarning to False
37237>>>        End
37237>>>>
37237>>>        Else Begin
37238>>>            WebSet pbVisible of oWarning to True
37239>>>        End
37239>>>>
37239>>>    End_Procedure
37240>>>    
37240>>>    Procedure OnSubmit
37243>>>        Send DoLogin
37244>>>    End_Procedure
37245>>>    
37245>>>    Procedure OnLoad
37248>>>        String sPrevStateHash sView
37248>>>        
37248>>>        Forward Send OnLoad
37250>>>        
37250>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37250>>>        Get StateHash of ghoWebApp to sPrevStateHash
37251>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37252>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37254>>>            WebSet psPrevStateHash to sPrevStateHash
37255>>>        End
37255>>>>
37255>>>        
37255>>>    End_Procedure
37256>>>    
37256>>>    Procedure OnBeforeShow
37259>>>        //  Hide header & apply nice background style
37259>>>        Send HideHeader to ghoWebApp
37260>>>        WebSet psCSSClass of ghoWebApp to "LoginBackground"
37261>>>    End_Procedure
37262>>>    
37262>>>End_Object
