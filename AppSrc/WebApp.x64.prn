36516>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36517>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36518>>>>>>>        
36518>>>>>>>        //  Fill out with 0
36518>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36521>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36524>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36527>>>>>>>        
