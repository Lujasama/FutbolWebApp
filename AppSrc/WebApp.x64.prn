36987>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
36989>>>>>        Handle hoUserDD
36989>>>>>        Integer iErr
36989>>>>>        Get phoUserDD to hoUserDD
36990>>>>>        
36990>>>>>        //  Find the user
36990>>>>>        Send Clear of hoUserDD
36991>>>>>        Move sLoginName to WebAppUser.LoginName
36992>>>>>        Send Find of hoUserDD EQ Index.1
36993>>>>>        If (Found) Begin
36995>>>>>            Send Clear of hoUserDD
36996>>>>>            Function_Return False
36997>>>>>        End
36997>>>>>>
36997>>>>>        
36997>>>>>        Send Clear of hoUserDD
36998>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
36999>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37000>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37002>>>>>            Send Clear of hoUserDD
37003>>>>>            Function_Return False
37004>>>>>        End
37004>>>>>>
37004>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37005>>>>>        Get Request_Validate of hoUserDD to iErr
37006>>>>>        If (iErr) Begin
37008>>>>>            Send Clear of hoUserDD
37009>>>>>            Function_Return False
37010>>>>>        End
37010>>>>>>
37010>>>>>        
37010>>>>>        Send Request_Save of hoUserDD
37011>>>>>        Function_Return (not(Err))
37012>>>>>    End_Function
37013>>>>>    
37013>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37015>>>>>        String sSessionKey sUserPassword
37015>>>>>        Handle hoSessionDD hoUserDD
37015>>>>>        Boolean bMatch bUpgrade
37015>>>>>        
37015>>>>>        Get phoSessionDD to hoSessionDD
37016>>>>>        Get phoUserDD to hoUserDD
37017>>>>>        Integer iErr eLoginMode
37017>>>>>        
37017>>>>>        // Refind session record
37017>>>>>        Get psSessionKey to sSessionKey
37018>>>>>        Send Clear of hoSessionDD
37019>>>>>        Move sSessionKey to WebAppSession.SessionKey
37020>>>>>        Send Find of hoSessionDD EQ Index.1
37021>>>>>        
37021>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37023>>>>>            Get peLoginMode to eLoginMode
37024>>>>>            
37024>>>>>            //  Find the user
37024>>>>>            Move sLoginName to WebAppUser.LoginName
37025>>>>>            Send Find of hoUserDD EQ Index.1
37026>>>>>            
37026>>>>>            // Check username and password
37026>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37028>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37029>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37030>>>>>                
37030>>>>>                If (bMatch) Begin
37032>>>>>                    // Store the login
37032>>>>>                    If (bUpgrade) Begin
37034>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37035>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37038>>>>>                    End
37038>>>>>>
37038>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37039>>>>>                    Get Request_Validate of hoSessionDD to iErr
37040>>>>>                    If (iErr) Begin
37042>>>>>                        // this should not happen. If it does its a programming error
37042>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37043>>>>>>
37043>>>>>                        Function_Return False
37044>>>>>                    End
37044>>>>>>
37044>>>>>                    
37044>>>>>                    Send Request_Save of hoSessionDD
37045>>>>>                    
37045>>>>>                    // Update session properties
37045>>>>>                    Send UpdateSessionProperties False
37046>>>>>                    Send NotifyChangeRights
37047>>>>>                    Function_Return True
37048>>>>>                End
37048>>>>>>
37048>>>>>                Else Begin
37049>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37049>>>>>                    Send Clear of hoUserDD
37050>>>>>                End
37050>>>>>>
37050>>>>>            End
37050>>>>>>
37050>>>>>            Else Begin
37051>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37051>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37052>>>>>            End
37052>>>>>>
37052>>>>>        End
37052>>>>>>
37052>>>>>        Else Begin
37053>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37053>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37054>>>>>        End
37054>>>>>>
37054>>>>>          
37054>>>>>        Function_Return False
37055>>>>>    End_Function
37056>>>>>    
37056>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37058>>>>>        Handle hoUserDD
37058>>>>>        Integer iErr
37058>>>>>        Get phoUserDD to hoUserDD
37059>>>>>        
37059>>>>>        //  Find the user
37059>>>>>        Send Clear of hoUserDD
